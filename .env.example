# Copy this file to .env and fill in your Supabase project credentials.
# Find these values in: Supabase Dashboard → Project Settings → API
#
# IMPORTANT: Never commit .env to version control.
# The anon key is safe to expose client-side (Supabase RLS enforces access),
# but keep it out of git as a general practice.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
